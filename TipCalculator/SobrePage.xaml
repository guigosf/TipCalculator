<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TipCalculator.SobrePage"
             Title="">

    <VerticalStackLayout>
        <Border
                WidthRequest="200" 
                HeightRequest="200"
                Stroke="Violet"
                StrokeThickness="3"
                StrokeShape="RoundRectangle 50,50,50,50"
                Padding="16,8"
                HorizontalOptions="Center">>
            <Image Source="dotnet_bot.png"
            />
        </Border>
        <Label 
            Text="Feito por: Guilherme dos Santos Ferreira"
            VerticalOptions="Center" 
            HorizontalOptions="Center" />


        <Button
                x:Name="GithubButton"
                Text="Ir para o repositório"
                SemanticProperties.Hint="Link do meu github"
                Clicked="GithubButton_Clicked"
                />
    </VerticalStackLayout>

</ContentPage>